<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SuperDemos - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  </head>
  <body class="bg-gray-100">
    <div id="app" class="min-h-screen">
      <div class="bg-white shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
          <div class="flex justify-between items-center">
            <div>
              <h1 class="text-2xl font-bold text-gray-900">SuperDemos</h1>
              <p class="text-sm text-gray-600 mt-1">Create interactive product demos via SDK + WebSocket authoring.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
        <div v-if="toast.show" class="fixed top-4 right-4 z-50">
          <div :class="['px-4 py-3 rounded shadow text-sm', toast.type === 'error' ? 'bg-red-600 text-white' : 'bg-green-600 text-white']">
            {{ toast.message }}
          </div>
        </div>

        <div class="bg-white rounded-lg shadow p-4">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div>
              <h2 class="font-semibold text-gray-800">SDK embed (quick)</h2>
              <p class="text-xs text-gray-500">Paste this in your external app/website. It enables both live + author mode.</p>
            </div>
          </div>
          <pre class="mt-3 text-[11px] bg-gray-50 border border-gray-200 rounded p-2 whitespace-pre-wrap break-words"><code>&lt;script src="{{ origin }}<%= baseUrl %>/public/sdk/superdemos.iife.js"&gt;&lt;/script&gt;
&lt;script&gt;
  SuperDemos.init({
    projectId: 'sdp_yourproject',
    apiUrl: '{{ origin }}<%= baseUrl %>',
    apiKey: null, // set if private
    mode: 'live',
  });
&lt;/script&gt;</code></pre>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="bg-white rounded-lg shadow p-4 space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="font-semibold text-gray-800">Projects</h2>
              <button @click="refreshAll" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200">Refresh</button>
            </div>

            <div class="space-y-2">
              <input v-model="newProject.name" class="w-full border rounded px-3 py-2 text-sm" placeholder="Project name" />
              <input v-model="newProject.projectId" class="w-full border rounded px-3 py-2 text-sm" placeholder="projectId (optional, sdp_...)" />
              <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" v-model="newProject.isPublic" />
                Public
              </label>
              <button @click="createProject" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm px-3 py-2 rounded">Create project</button>
            </div>

            <div v-if="lastGeneratedKey" class="text-xs bg-amber-50 border border-amber-200 rounded p-2">
              <div class="font-semibold">Project API key (copy now)</div>
              <div class="flex items-start gap-2">
                <div class="font-mono break-words flex-1">{{ lastGeneratedKey }}</div>
                <button @click="copyText(lastGeneratedKey, 'Project API key')" class="text-xs px-2 py-1 rounded bg-amber-200 hover:bg-amber-300">Copy</button>
              </div>
            </div>

            <div class="border-t pt-3">
              <div class="text-xs text-gray-500 mb-2">Select a project:</div>
              <div class="space-y-1 max-h-[420px] overflow-auto">
                <button
                  v-for="(p, pIdx) in (projects || [])"
                  :key="(p && p.projectId) || ('p-' + pIdx)"
                  @click="selectProject(p)"
                  :class="['w-full text-left px-3 py-2 rounded text-sm border', selectedProject && p && selectedProject.projectId === p.projectId ? 'bg-blue-50 border-blue-300' : 'bg-white border-gray-200 hover:bg-gray-50']"
                >
                  <div class="font-medium text-gray-900">{{ (p && p.name) || 'Unnamed project' }}</div>
                  <div class="text-xs text-gray-500 flex items-center gap-2 flex-wrap">
                    <span>{{ (p && p.projectId) || '-' }}</span>
                    <button @click.stop="copyText(p && p.projectId, 'Project ID')" class="px-2 py-0.5 rounded bg-gray-100 hover:bg-gray-200">Copy ID</button>
                    <span>·</span>
                    <span :class="(p && p.isPublic) ? 'text-green-600' : 'text-amber-600'">{{ (p && p.isPublic) ? 'public' : 'private' }}</span>
                  </div>
                </button>
              </div>
            </div>
            <div class="border-t pt-3 space-y-2" v-if="selectedProject">
              <div class="text-xs font-semibold text-gray-700">Project demo style</div>
              <select v-model="projectStylePreset" class="w-full border rounded px-2 py-2 text-sm">
                <option value="default">default</option>
                <option value="glass-dark">glass-dark</option>
                <option value="high-contrast">high-contrast</option>
                <option value="soft-purple">soft-purple</option>
              </select>
              <textarea v-model="projectStyleOverrides" rows="4" class="w-full border rounded px-2 py-2 text-xs font-mono" placeholder="Custom CSS override (optional)"></textarea>
              <button @click="saveProjectStyleSettings" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-3 py-2 rounded">Save style settings</button>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-4 space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="font-semibold text-gray-800">Demos</h2>
            </div>

            <div v-if="!selectedProject" class="text-sm text-gray-500">Select a project to manage demos.</div>

            <div v-if="selectedProject" class="space-y-2">
              <input v-model="newDemo.name" class="w-full border rounded px-3 py-2 text-sm" placeholder="Demo name" />
              <input v-model="newDemo.startUrlPattern" class="w-full border rounded px-3 py-2 text-sm" placeholder="startUrlPattern (optional substring)" />
              <button @click="createDemo" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm px-3 py-2 rounded">Create demo</button>
            </div>

            <div class="border-t pt-3" v-if="selectedProject">
              <div class="text-xs text-gray-500 mb-2">Select a demo:</div>
              <div class="space-y-1 max-h-[420px] overflow-auto">
                <button
                  v-for="(d, dIdx) in (demos || [])"
                  :key="(d && d.demoId) || ('d-' + dIdx)"
                  @click="selectDemo(d)"
                  :class="['w-full text-left px-3 py-2 rounded text-sm border', selectedDemo && d && selectedDemo.demoId === d.demoId ? 'bg-blue-50 border-blue-300' : 'bg-white border-gray-200 hover:bg-gray-50']"
                >
                  <div class="font-medium text-gray-900">{{ (d && d.name) || 'Unnamed demo' }}</div>
                  <div class="text-xs text-gray-500 flex items-center gap-2 flex-wrap">
                    <span>{{ (d && d.demoId) || '-' }}</span>
                    <button @click.stop="copyText(d && d.demoId, 'Demo ID')" class="px-2 py-0.5 rounded bg-gray-100 hover:bg-gray-200">Copy ID</button>
                    <span>·</span>
                    <span :class="(d && d.status) === 'published' ? 'text-green-700' : 'text-gray-600'">{{ (d && d.status) || 'draft' }}</span>
                    <span>·</span>
                    <span>v{{ (d && d.publishedVersion) || 0 }}</span>
                  </div>
                </button>
              </div>
            </div>

            <div v-if="selectedDemo" class="border-t pt-3 space-y-2">
              <button @click="publishDemo" class="w-full bg-green-600 hover:bg-green-700 text-white text-sm px-3 py-2 rounded">Publish</button>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-4 space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="font-semibold text-gray-800">Steps & Authoring</h2>
            </div>

            <div v-if="!selectedDemo" class="text-sm text-gray-500">Select a demo to edit steps.</div>

            <div v-if="selectedDemo" class="space-y-3">
              <div class="border rounded p-3 space-y-2">
                <div class="font-semibold text-sm text-gray-800">Authoring session</div>
                <div class="text-xs bg-blue-50 border border-blue-200 rounded p-2 space-y-1">
                  <div class="font-semibold text-blue-900">QA quick start</div>
                  <div>
                    <a class="text-blue-700 underline break-all" :href="qaPageUrl" target="_blank" rel="noreferrer">{{ qaPageUrl }}</a>
                  </div>
                  <div class="flex gap-2">
                    <button @click="setQaTargetUrl" class="text-xs px-2 py-1 rounded bg-blue-600 hover:bg-blue-700 text-white">Use QA page as target</button>
                    <a :href="qaPageUrl" target="_blank" rel="noreferrer" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200">Open QA page</a>
                  </div>
                </div>
                <input v-model="authoring.targetUrl" class="w-full border rounded px-3 py-2 text-sm" placeholder="Target URL to open (new window)" />
                <button @click="startAuthoring" class="w-full bg-purple-600 hover:bg-purple-700 text-white text-sm px-3 py-2 rounded">Start authoring</button>

                <div v-if="authoring.connectUrl" class="text-xs bg-gray-50 border border-gray-200 rounded p-2 space-y-2">
                  <div>
                    <div class="font-semibold">Open this URL (new tab)</div>
                    <a class="text-blue-700 underline break-words" :href="authoring.connectUrl" target="_blank" rel="noreferrer">{{ authoring.connectUrl }}</a>
                  </div>
                  <div class="text-gray-600">
                    WS: <span class="font-mono">{{ authoring.wsStatus }}</span>
                  </div>
                </div>
              </div>

              <div class="border rounded p-3 space-y-2">
                <div class="flex items-center justify-between gap-2">
                  <div>
                    <div class="font-semibold text-sm text-gray-800">Selected element (from SDK)</div>
                    <div class="text-xs text-gray-500">Click an element in the target app while authoring.</div>
                  </div>
                  <button @click="addStepFromSelection" class="text-xs px-3 py-2 rounded bg-gray-900 hover:bg-gray-800 text-white">Add step</button>
                </div>
                <div class="text-xs font-mono bg-gray-50 border border-gray-200 rounded p-2 break-words" v-if="lastSelection">
                  {{ lastSelection.selector }}
                </div>
                <div class="text-xs text-gray-500" v-else>No selection yet.</div>
              </div>

              <div class="border rounded p-3 space-y-2">
                <div class="flex items-center justify-between">
                  <div class="font-semibold text-sm text-gray-800">Steps</div>
                  <button @click="saveSteps" class="text-xs px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white">Save</button>
                </div>

                <div class="space-y-2 max-h-[420px] overflow-auto">
                  <div v-for="(s, idx) in steps" :key="idx" class="border border-gray-200 rounded p-2 space-y-2">
                    <div class="text-xs text-gray-500">#{{ idx + 1 }}</div>
                    <input v-model="s.selector" class="w-full border rounded px-2 py-1 text-xs font-mono" placeholder="selector" />
                    <input v-model="s.message" class="w-full border rounded px-2 py-1 text-sm" placeholder="message" />
                    <div class="grid grid-cols-2 gap-2">
                      <select v-model="s.placement" class="w-full border rounded px-2 py-1 text-sm">
                        <option value="auto">auto</option>
                        <option value="top">top</option>
                        <option value="bottom">bottom</option>
                        <option value="left">left</option>
                        <option value="right">right</option>
                      </select>
                      <select v-model="s.advance.type" class="w-full border rounded px-2 py-1 text-sm">
                        <option value="manualNext">manualNext</option>
                        <option value="clickTarget">clickTarget</option>
                        <option value="delayMs">delayMs</option>
                      </select>
                    </div>
                    <div v-if="s.advance.type === 'delayMs'" class="grid grid-cols-2 gap-2">
                      <input v-model.number="s.advance.ms" type="number" class="w-full border rounded px-2 py-1 text-sm" placeholder="ms" />
                    </div>
                    <div class="flex gap-2">
                      <button @click="removeStep(idx)" class="text-xs px-2 py-1 rounded bg-red-600 hover:bg-red-700 text-white">Remove</button>
                      <button @click="moveStep(idx, -1)" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200">Up</button>
                      <button @click="moveStep(idx, 1)" class="text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200">Down</button>
                      <button @click="previewStep(s)" class="ml-auto text-xs px-2 py-1 rounded bg-purple-600 hover:bg-purple-700 text-white">Preview</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      window.__adminSuperDemosConfig = {
        baseUrl: '<%= baseUrl %>',
        adminPath: '<%= adminPath %>',
      };
    </script>
    <script src="<%= baseUrl %>/public/js/admin-superdemos.js"></script>
  </body>
</html>
